    "    \"        }\\n\",\n",
    "    \"    });\\n\",\n",
    "    \"\\n\",\n",
    "    \"    async function speakStory() {\\n\",\n",
    "    \"        const text = document.getElementById('story-content').innerText;\\n\",\n",
    "    \"        const res = await fetch(\\\"/speak\\\", {\\n\",\n",
    "    \"            method: \\\"POST\\\",\\n\",\n",
    "    \"            headers: { \\\"Content-Type\\\": \\\"application/json\\\" },\\n\",\n",
    "    \"            body: JSON.stringify({ text: text })\\n\",\n",
    "    \"        });\\n\",\n",
    "    \"        const data = await res.json();\\n\",\n",
    "    \"        new Audio(data.url).play();\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"</script>\\n\",\n",
    "    \"</body>\\n\",\n",
