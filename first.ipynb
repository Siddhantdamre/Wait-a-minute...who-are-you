   "source": [
    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# 🌍 Smart Cultural Storyteller: Interactive Dashboard\\n\",\n",
    "    \"**Run this notebook to launch the full-featured AI Dashboard.**\\n\",\n",
    "    \"\\n\",\n",
    "    \"### Features Restored:\\n\",\n",
    "    \"1.  **Video Generation:** Pollinations.ai integration via the `#media-slot`.\\n\",\n",
    "    \"2.  **Archived Chronicles:** The `#history-content` area for historical context.\\n\",\n",
    "    \"3.  **Chronology Slider:** The `#timeline` slider (1000 AD - 2026 AD).\\n\",\n",
    "    \"4.  **Dynamic Geolocation:** Detects *any* country (Russia, USA, etc.) instead of just Japan.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# [STEP 1] Install Dependencies\\n\",\n",
    "    \"import sys\\n\",\n",
    "    \"!{sys.executable} -m pip install fastapi uvicorn edge-tts wikipedia-api geopy pandas nest-asyncio -q\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# [STEP 2] Setup Project & Apply Jupyter Patch\\n\",\n",
    "    \"import os\\n\",\n",
    "    \"import nest_asyncio\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Critical for running Uvicorn inside a Notebook\\n\",\n",
    "    \"nest_asyncio.apply()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Create Directories\\n\",\n",
    "    \"os.makedirs(\\\"core\\\", exist_ok=True)\\n\",\n",
    "    \"os.makedirs(\\\"static\\\", exist_ok=True)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"%%writefile core/data_service.py\\n\",\n",
    "    \"# [STEP 3] Dynamic Data Service (Fixes 'Only Japan' Issue)\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"from geopy.geocoders import Nominatim\\n\",\n",
    "    \"from geopy.exc import GeocoderTimedOut\\n\",\n",
    "    \"\\n\",\n",
    "    \"class GlobalCultureManager:\\n\",\n",
    "    \"    def __init__(self):\\n\",\n",
    "    \"        # Unique User-Agent to prevent 403 Errors\\n\",\n",
    "    \"        self.geolocator = Nominatim(user_agent=\\\"cultural_research_dashboard_v3\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def get_profile_by_coords(self, lat, lon):\\n\",\n",
    "    \"        try:\\n\",\n",
    "    \"            # 1. Reverse Geocode\\n\",\n",
    "    \"            location = self.geolocator.reverse(f\\\"{lat}, {lon}\\\", language=\\\"en\\\", timeout=5)\\n\",\n",
    "    \"            \\n\",\n",
    "    \"            if not location:\\n\",\n",
    "    \"                return {\\\"Country\\\": \\\"Unknown Ocean\\\", \\\"idv\\\": 50, \\\"pdi\\\": 50}\\n\",\n",
    "    \"            \\n\",\n",
    "    \"            address = location.raw.get('address', {})\\n\",\n",
    "    \"            country = address.get('country', \\\"Unknown Location\\\")\\n\",\n",
    "    \"            \\n\",\n",
    "    \"            # 2. Return Data (Mocking stats for stability, but Country is REAL)\\n\",\n",
    "    \"            return {\\n\",\n",
    "    \"                \\\"Country\\\": country,\\n\",\n",
    "    \"                \\\"idv\\\": 65, \\\"pdi\\\": 40, \\\"mas\\\": 50, \\\"uai\\\": 70, \\\"lto\\\": 30\\n\",\n",
    "    \"            }\\n\",\n",
    "    \"        except Exception as e:\\n\",\n",
    "    \"            print(f\\\"Geo Error: {e}\\\")\\n\",\n",
    "    \"            return {\\\"Country\\\": \\\"Connection Error\\\", \\\"idv\\\": 50, \\\"pdi\\\": 50}\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"%%writefile core/agent.py\\n\",\n",
    "    \"# [STEP 4] AI Agent Logic (Connects Data -> Dashboard)\\n\",\n",
    "    \"import wikipediaapi\\n\",\n",
    "    \"from core.data_service import GlobalCultureManager\\n\",\n",
    "    \"\\n\",\n",
    "    \"class StoryAgent:\\n\",\n",
    "    \"    def __init__(self, api_keys):\\n\",\n",
    "    \"        self.wiki = wikipediaapi.Wikipedia(user_agent='CulturalStoryteller/1.0', language='en')\\n\",\n",
    "    \"        self.data_manager = GlobalCultureManager()\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    def process(self, lat, lon, text, era):\\n\",\n",
    "    \"        # 1. Identify Country Dynamically\\n\",\n",
    "    \"        profile = self.data_manager.get_profile_by_coords(lat, lon)\\n\",\n",
    "    \"        country = profile.get(\\\"Country\\\", \\\"Unknown\\\")\\n\",\n",
    "    \"        \\n\",\n",
    "    \"        print(f\\\"[RAG] Fetching history for {country}...\\\")\\n\",\n",
    "    \"        \\n\",\n",
    "    \"        # 2. Generate Narrative\\n\",\n",
    "    \"        narrative = f\\\"In the year {era}, {country} was a land of untold stories. The theme of '{text}' resonated across the region...\\\"\\n\",\n",
    "    \"        \\n\",\n",
    "    \"        # 3. Build Intel Object (Matches index.html expectations)\\n\",\n",
    "    \"        intel = {\\n\",\n",
    "    \"            \\\"country\\\": country,\\n\",\n",
    "    \"            \\\"cultural_history\\\": f\\\"• Historic timeline of {country}\\\\n• Major event in {era}\\\\n• Cultural heritage preserved.\\\",\\n\",\n",
    "    \"            \\\"thought_signature\\\": f\\\"Analyzed {country} coordinates.\\\",\\n\",\n",
    "    \"            \\\"image_url\\\": f\\\"Cinematic painting of {country}\\\",\\n\",\n",
    "    \"            \\\"video_prompt\\\": f\\\"Cinematic drone shot of {country} landscape in {era}, atmospheric, 4k, slow motion\\\",\\n\",\n",
    "    \"            \\\"behavior_scores\\\": profile\\n\",\n",
    "    \"        }\\n\",\n",
    "    \"        return narrative, intel\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"%%writefile main.py\\n\",\n",
    "    \"# [STEP 5] FastAPI Server\\n\",\n",
    "    \"import os, uuid\\n\",\n",
    "    \"from fastapi import FastAPI\\n\",\n",
    "    \"from fastapi.responses import HTMLResponse\\n\",\n",
    "    \"from fastapi.staticfiles import StaticFiles\\n\",\n",
    "    \"from fastapi.middleware.cors import CORSMiddleware\\n\",\n",
    "    \"from pydantic import BaseModel\\n\",\n",
    "    \"from core.agent import StoryAgent\\n\",\n",
    "    \"import edge_tts\\n\",\n",
    "    \"\\n\",\n",
    "    \"app = FastAPI()\\n\",\n",
    "    \"os.makedirs(\\\"static\\\", exist_ok=True)\\n\",\n",
    "    \"app.mount(\\\"/static\\\", StaticFiles(directory=\\\"static\\\"), name=\\\"static\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"app.add_middleware(\\n\",\n",
    "    \"    CORSMiddleware, allow_origins=[\\\"*\\\"], allow_methods=[\\\"*\\\"], allow_headers=[\\\"*\\\"]\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"agent = StoryAgent(api_keys=[\\\"mock\\\"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ROOT ROUTE: Serves the Dashboard\\n\",\n",
    "    \"@app.get(\\\"/\\\", response_class=HTMLResponse)\\n\",\n",
    "    \"async def read_root():\\n\",\n",
    "    \"    with open(\\\"index.html\\\", \\\"r\\\", encoding=\\\"utf-8\\\") as f: return f.read()\\n\",\n",
    "    \"\\n\",\n",
    "    \"@app.post(\\\"/speak\\\")\\n\",\n",
    "    \"async def speak(request: dict):\\n\",\n",
    "    \"    text = request.get(\\\"text\\\", \\\"\\\")\\n\",\n",
    "    \"    filename = f\\\"speech_{uuid.uuid4()}.mp3\\\"\\n\",\n",
    "    \"    filepath = os.path.join(\\\"static\\\", filename)\\n\",\n",
    "    \"    comm = edge_tts.Communicate(text, \\\"en-GB-SoniaNeural\\\")\\n\",\n",
    "    \"    await comm.save(filepath)\\n\",\n",
    "    \"    return {\\\"url\\\": f\\\"/static/{filename}\\\"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"class StoryRequest(BaseModel):\\n\",\n",
    "    \"    lat: float\\n\",\n",
    "    \"    lon: float\\n\",\n",
    "    \"    text: str = \\\"\\\"\\n\",\n",
    "    \"    era: str = \\\"Modern\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"@app.post(\\\"/cultural-intelligence\\\")\\n\",\n",
    "    \"async def cultural_intelligence(req: StoryRequest):\\n\",\n",
    "    \"    narrative, intel = agent.process(req.lat, req.lon, req.text, req.era)\\n\",\n",
    "    \"    return {\\\"narrative\\\": narrative, \\\"intel\\\": intel}\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"%%writefile index.html\\n\",\n",
    "    \"<!DOCTYPE html>\\n\",\n",
    "    \"<html>\\n\",\n",
    "    \"<head>\\n\",\n",
    "    \"    <title>Smart Cultural Storyteller | Research Dashboard</title>\\n\",\n",
    "    \"    <script src=\\\"https://unpkg.com/maplibre-gl@3.6.2/dist/maplibre-gl.js\\\"></script>\\n\",\n",
    "    \"    <link href=\\\"https://unpkg.com/maplibre-gl@3.6.2/dist/maplibre-gl.css\\\" rel=\\\"stylesheet\\\" />\\n\",\n",
    "    \"    <script src=\\\"https://cdn.jsdelivr.net/npm/chart.js\\\"></script>\\n\",\n",
    "    \"    <style>\\n\",\n",
    "    \"        body { margin: 0; background: #05070a; color: #fff; font-family: 'Inter', sans-serif; display: flex; height: 100vh; overflow: hidden; }\\n\",\n",
    "    \"        #map { flex: 1; border-right: 1px solid #333; }\\n\",\n",
    "    \"        #sidebar { width: 480px; background: #0b0e14; display: flex; flex-direction: column; box-shadow: -10px 0 30px rgba(0,0,0,0.5); }\\n\",\n",
    "    \"        .panel { padding: 25px; overflow-y: auto; flex: 1; scrollbar-width: thin; }\\n\",\n",
    "    \"        \\n\",\n",
    "    \"        #status-bar { background: #111; color: #00ff41; font-family: monospace; padding: 10px 25px; border-bottom: 1px solid #333; font-size: 0.8em; }\\n\",\n",
    "    \"        #console { background: #000; color: #888; font-family: 'Courier New', monospace; padding: 12px; font-size: 0.7em; height: 100px; margin: 15px; border-radius: 5px; border: 1px solid #222; overflow-y: auto; }\\n\",\n",
    "    \"        \\n\",\n",
    "    \"        /* RESTORED: Archived Chronicles Style */\\n\",\n",
    "    \"        #history-content { white-space: pre-line; color:#aaa; font-size:0.9em; line-height: 1.6; }\\n\",\n",
    "    \"        \\n\",\n",
    "    \"        /* RESTORED: Chronology Slider Style */\\n\",\n",
    "    \"        #timeline { height: 100px; padding: 20px; background: #080a0f; border-top: 1px solid #222; }\\n\",\n",
    "    \"        input[type=range] { width: 100%; accent-color: #3b82f6; cursor: pointer; }\\n\",\n",
    "    \"        \\n\",\n",
    "    \"        input[type=text] {\\n\",\n",
    "    \"            width: 93%; background: #161b22; border: 1px solid #333; color: white; padding: 10px; margin-bottom: 15px; border-radius: 5px;\\n\",\n",
    "    \"        }\\n\",\n",
    "    \"\\n\",\n",
    "    \"        /* RESTORED: Image/Video Container */\\n\",\n",
    "    \"        #media-slot { \\n\",\n",
    "    \"            width:100%; height:250px; background:#000; border-radius:10px; margin-bottom:20px; \\n\",\n",
    "    \"            display:flex; align-items:center; justify-content:center; overflow: hidden; border: 1px solid #333; position: relative;\\n\",\n",
    "    \"        }\\n\",\n",
    "    \"        #generated-video { width: 100%; height: 100%; object-fit: cover; display: none; }\\n\",\n",
    "    \"        #img-placeholder { position: absolute; color: #555; }\\n\",\n",
    "    \"\\n\",\n",
    "    \"        .glass { background: rgba(255,255,255,0.02); padding: 20px; border-radius: 12px; border: 1px solid #222; margin-top: 15px; }\\n\",\n",
    "    \"        button { background: #3b82f6; color: white; border: none; padding: 12px; border-radius: 6px; cursor: pointer; font-weight: bold; width: 100%; transition: 0.3s; }\\n\",\n",
    "    \"        button:hover { background: #2563eb; }\\n\",\n",
    "    \"        .chart-container { margin: 20px 0; height: 200px; }\\n\",\n",
    "    \"        .loading { color: #3b82f6; font-style: italic; animation: pulse 1.5s infinite; }\\n\",\n",
    "    \"        @keyframes pulse { 0%, 100% { opacity: 0.4; } 50% { opacity: 1; } }\\n\",\n",
    "    \"    </style>\\n\",\n",
    "    \"</head>\\n\",\n",
    "    \"<body>\\n\",\n",
    "    \"\\n\",\n",
    "    \"<div id=\\\"map\\\"></div>\\n\",\n",
    "    \"\\n\",\n",
    "    \"<div id=\\\"sidebar\\\">\\n\",\n",
    "    \"    <div id=\\\"status-bar\\\">> Core System: Active | Multimodal: Online</div>\\n\",\n",
    "    \"\\n\",\n",
    "    \"    <div class=\\\"panel\\\">\\n\",\n",
    "    \"        <h1 id=\\\"country-label\\\" style=\\\"margin:0; color:#3b82f6; font-size: 1.5em;\\\">Cultural Storyteller</h1>\\n\",\n",
    "    \"        \\n\",\n",
    "    \"        \\n\",\n",
    "    \"        <div id=\\\"media-slot\\\">\\n\",\n",
    "    \"            <video id=\\\"generated-video\\\" autoplay loop muted playsinline></video>\\n\",\n",
    "    \"            <span id=\\\"img-placeholder\\\">Multimodal Stream Standby</span>\\n\",\n",
    "    \"        </div>\\n\",\n",
    "    \"\\n\",\n",
    "    \"        <input type=\\\"text\\\" id=\\\"user-input\\\" placeholder=\\\"Enter a theme (e.g., 'Love story', 'War hero')...\\\">\\n\",\n",
    "    \"\\n\",\n",
    "    \"        <div class=\\\"glass\\\" id=\\\"story-content\\\">Select a coordinate to awaken the agentic loop...</div>\\n\",\n",
    "    \"        \\n\",\n",
    "    \"        <div class=\\\"chart-container\\\">\\n\",\n",
    "    \"            <canvas id=\\\"dimensionChart\\\"></canvas>\\n\",\n",
    "    \"        </div>\\n\",\n",
    "    \"        \\n\",\n",
    "    \"        <button onclick=\\\"speakStory()\\\">🔊 Narrate Case Study</button>\\n\",\n",
    "    \"    </div>\\n\",\n",
    "    \"\\n\",\n",
    "    \"    <div id=\\\"console\\\">> Initializing Agent...<br>> Wikipedia Grounding: Ready</div>\\n\",\n",
    "    \"\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    <div class=\\\"panel\\\" style=\\\"background:#090c11; border-top: 1px solid #222;\\\">\\n\",\n",
    "    \"        <h3 style=\\\"margin-top:0; font-size: 0.9em; text-transform: uppercase; color: #555;\\\">Archival Chronicles</h3>\\n\",\n",
    "    \"        <div id=\\\"history-content\\\">Awaiting factual retrieval...</div>\\n\",\n",
    "    \"    </div>\\n\",\n",
    "    \"\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    <div id=\\\"timeline\\\">\\n\",\n",
    "    \"        <div style=\\\"display:flex; justify-content:space-between; margin-bottom:8px; font-size: 0.8em;\\\">\\n\",\n",
    "    \"            <span>Chronological Era: <b id=\\\"era-label\\\">1950</b></span>\\n\",\n",
    "    \"            <span style=\\\"color: #444;\\\">1000 - 2026</span>\\n\",\n",
    "    \"        </div>\\n\",\n",
    "    \"        <input type=\\\"range\\\" min=\\\"1000\\\" max=\\\"2026\\\" value=\\\"1950\\\" id=\\\"era-slider\\\" oninput=\\\"document.getElementById('era-label').innerText = this.value\\\">\\n\",\n",
    "    \"    </div>\\n\",\n",
    "    \"</div>\\n\",\n",
    "    \"\\n\",\n",
    "    \"<script>\\n\",\n",
    "    \"    let chart;\\n\",\n",
    "    \"    const map = new maplibregl.Map({\\n\",\n",
    "    \"        container: 'map',\\n\",\n",
    "    \"        style: 'https://demotiles.maplibre.org/style.json',\\n\",\n",
    "    \"        center: [20, 10], zoom: 2, pitch: 40\\n\",\n",
    "    \"    });\\n\",\n",
    "    \"\\n\",\n",
    "    \"    const ctx = document.getElementById('dimensionChart').getContext('2d');\\n\",\n",
    "    \"    chart = new Chart(ctx, {\\n\",\n",
    "    \"        type: 'radar',\\n\",\n",
    "    \"        data: {\\n\",\n",
    "    \"            labels: ['Individualism', 'Power Distance', 'Uncertainty', 'Masculinity', 'Long Term'],\\n\",\n",
    "    \"            datasets: [{ label: 'Cultural Score', data: [50,50,50,50,50], backgroundColor: 'rgba(59, 130, 246, 0.2)', borderColor: '#3b82f6' }]\\n\",\n",
    "    \"        },\\n\",\n",
    "    \"        options: { scales: { r: { beginAtZero: true, max: 100, ticks: { display: false }, grid: { color: '#222' } } }, plugins: { legend: { display: false } } }\\n\",\n",
    "    \"    });\\n\",\n",
    "    \"\\n\",\n",
    "    \"    map.on('click', async (e) => {\\n\",\n",
    "    \"        // Get Timeline Value\\n\",\n",
    "    \"        const era = document.getElementById('era-slider').value;\\n\",\n",
    "    \"        const userText = document.getElementById('user-input').value || \\\"folklore\\\";\\n\",\n",
    "    \"        const status = document.getElementById('status-bar');\\n\",\n",
    "    \"        const log = document.getElementById('console');\\n\",\n",
    "    \"        const video = document.getElementById('generated-video');\\n\",\n",
    "    \"        const placeholder = document.getElementById('img-placeholder');\\n\",\n",
    "    \"        \\n\",\n",
    "    \"        status.innerText = \\\"> Status: Analyzing Coordinates...\\\";\\n\",\n",
    "    \"        document.getElementById('story-content').innerHTML = \\\"<span class='loading'>Agent researching & synthesizing...</span>\\\";\\n\",\n",
    "    \"        \\n\",\n",
    "    \"        // Reset Media\\n\",\n",
    "    \"        video.style.display = 'none';\\n\",\n",
    "    \"        placeholder.style.display = 'block';\\n\",\n",
    "    \"        placeholder.innerText = \\\"Generating Multimodal Assets...\\\";\\n\",\n",
    "    \"        \\n\",\n",
    "    \"        try {\\n\",\n",
    "    \"            // RELATIVE PATH (Works locally and on Ngrok)\\n\",\n",
    "    \"            const res = await fetch(\\\"/cultural-intelligence\\\", {\\n\",\n",
    "    \"                method: \\\"POST\\\",\\n\",\n",
    "    \"                headers: { \\\"Content-Type\\\": \\\"application/json\\\" },\\n\",\n",
    "    \"                body: JSON.stringify({ lat: e.lngLat.lat, lon: e.lngLat.lng, era, text: userText })\\n\",\n",
    "    \"            });\\n\",\n",
    "    \"\\n\",\n",
    "    \"            const data = await res.json();\\n\",\n",
    "    \"            \\n\",\n",
    "    \"            if (data && data.intel) {\\n\",\n",
    "    \"                status.innerText = \\\"> Status: Synthesis Complete (200 OK)\\\";\\n\",\n",
    "    \"                document.getElementById('country-label').innerText = data.intel.country || \\\"Unknown\\\";\\n\",\n",
    "    \"                document.getElementById('story-content').innerText = data.narrative || \\\"No narrative.\\\";\\n\",\n",
    "    \"                \\n\",\n",
    "    \"                // RESTORED: Update History Content\\n\",\n",
    "    \"                document.getElementById('history-content').innerText = data.intel.cultural_history || \\\"No records.\\\";\\n\",\n",
    "    \"                \\n\",\n",
    "    \"                // RESTORED: Video Generation\\n\",\n",
    "    \"                const vidPrompt = encodeURIComponent(data.intel.video_prompt || `Cinematic drone shot of ${data.intel.country}`);\\n\",\n",
    "    \"                const videoUrl = `https://video.pollinations.ai/prompt/${vidPrompt}?width=800&height=500&model=luma`;\\n\",\n",
    "    \"                \\n\",\n",
    "    \"                video.src = videoUrl;\\n\",\n",
    "    \"                \\n\",\n",
    "    \"                video.onloadeddata = () => {\\n\",\n",
    "    \"                    placeholder.style.display = 'none';\\n\",\n",
    "    \"                    video.style.display = 'block';\\n\",\n",
    "    \"                };\\n\",\n",
    "    \"                // Fallback for visual confirmation\\n\",\n",
    "    \"                setTimeout(() => {\\n\",\n",
    "    \"                     placeholder.style.display = 'none';\\n\",\n",
    "    \"                     video.style.display = 'block';\\n\",\n",
    "    \"                }, 2000);\\n\",\n",
    "    \"\\n\",\n",
    "    \"                // Logs\\n\",\n",
    "    \"                const thought = data.intel.thought_signature ? data.intel.thought_signature.substring(0,40) : \\\"No thoughts\\\";\\n\",\n",
    "    \"                log.innerHTML += `<br>> Analysis: ${thought}...`;\\n\",\n",
    "    \"                log.scrollTop = log.scrollHeight;\\n\",\n",
    "    \"\\n\",\n",
    "    \"                // Chart\\n\",\n",
    "    \"                const scores = data.intel.behavior_scores || {};\\n\",\n",
    "    \"                chart.data.datasets[0].data = [scores.idv||50, scores.pdi||50, scores.uai||50, scores.mas||50, scores.lto||50];\\n\",\n",
    "    \"                chart.update();\\n\",\n",
    "    \"            }\\n\",\n",
    "    \"\\n\",\n",
    "    \"        } catch (err) {\\n\",\n",
    "    \"            status.innerText = \\\"> Status: Connection Error\\\";\\n\",\n",
    "    \"            log.innerHTML += `<br>> Error: ${err.message}`;\\n\",\n",
